# ============================================================
# Supply Chain Analytics Agent — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git — it contains secrets!
# ============================================================

# Anthropic API Key (required)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Claude model to use (optional — defaults to claude-sonnet-4-20250514)
# Available models on your account can be listed via the Anthropic API
CLAUDE_MODEL=claude-sonnet-4-20250514

# Path to CSV data files (optional — defaults to ./data)
DATA_DIR=./data
