# ============================================================
# Supply Chain Analytics Agent — .gitignore
# ============================================================

# ---------------------------
# Python
# ---------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
wheels/

# Virtual environments
venv/
.venv/
env/
ENV/
.env.bak

# ---------------------------
# Environment / Secrets  ← NEVER commit these
# ---------------------------
.env
.env.*
!.env.example
*.key
*.pem
secrets.json

# ---------------------------
# Node / Frontend
# ---------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp/
.pnp.js
frontend/build/
frontend/.cache/

# ---------------------------
# Docker
# ---------------------------
.dockerignore

# ---------------------------
# IDE / Editor
# ---------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------------------------
# Logs
# ---------------------------
*.log
logs/
log/

# ---------------------------
# Testing / Coverage
# ---------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage.xml
*.cover

# ---------------------------
# Jupyter
# ---------------------------
.ipynb_checkpoints/
*.ipynb

# ---------------------------
# OS
# ---------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
